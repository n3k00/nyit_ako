BOT_TOKEN=your_telegram_bot_token_here
BOT_USERNAME=NekoBot
BOT_STARTUP_CHECK_ONLY=false

# Leave WEBHOOK_URL empty for local polling mode.
WEBHOOK_URL=
WEBHOOK_PORT=8080

# Provider can be openai_compatible or mock.
LLM_PROVIDER=openai_compatible
LLM_API_BASE=https://api.xiaomimimo.com/v1
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=mimo-v2.5-pro
LLM_TIMEOUT_MS=20000
LLM_RETRIES=1

# Bounded short-lived context.
MAX_CONTEXT_MESSAGES=80
RECENT_CONTEXT_LIMIT=30
MESSAGE_TTL_MINUTES=180
MAX_MESSAGE_LENGTH=2000

# Spam controls.
RATE_LIMIT_PER_MINUTE=3
GROUP_RATE_LIMIT_PER_MINUTE=20
COOLDOWN_MS=4000

# Safe group style defaults.
DEFAULT_REPLY_LENGTH=short
DEFAULT_HUMOR_LEVEL=1
DEFAULT_ROAST_LEVEL=1

# Ambient group-friend replies: natural joins, not every message.
AMBIENT_REPLIES_ENABLED=true
AMBIENT_MAX_PER_MINUTE=2
AMBIENT_COOLDOWN_SECONDS=25
AMBIENT_CONTEXT_MESSAGES=20
AMBIENT_MIN_MESSAGE_LENGTH=3

# Private files are optional and must never be committed.
GROUP_PROFILE_PATH=private_context/telegram_group_behavior_profile.json
MEMBER_PROFILES_PATH=private_context/telegram_member_interaction_profiles.json
LOCAL_DB_PATH=data/local_db.json
