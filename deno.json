{
  "tasks": {
    "dev": "deno run --env-file=.env --allow-net --allow-env --allow-read --allow-write --allow-import --watch src/bot.ts",
    "serve": "deno run --env-file=.env --allow-net --allow-env --allow-read --allow-write --allow-import src/bot.ts",
    "check": "deno check --allow-import src/bot.ts supabase/functions/telegram-bot/index.ts",
    "test": "deno test --allow-read --allow-write --allow-env --allow-import",
    "lint": "deno lint",
    "fmt": "deno fmt"
  },
  "imports": {
    "@grammyjs/types": "https://deno.land/x/grammy_types@v1.16.0/mod.ts",
    "grammy": "https://deno.land/x/grammy@v1.25.0/mod.ts",
    "@supabase/supabase-js": "https://esm.sh/@supabase/supabase-js@2.45.0"
  },
  "compilerOptions": {
    "lib": ["deno.window"],
    "strict": true
  }
}
